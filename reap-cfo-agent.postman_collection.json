          "mode": "raw",
          "raw": "{\n  \"transaction_id\": \"{{txnId}}\",\n  \"tenant_id\": \"{{tenantId}}\",\n  \"action\": \"OVERRIDDEN\",\n  \"final_code\": \"{{finalCode}}\",\n  \"accountant_id\": \"{{accountantId}}\"\n}" 
